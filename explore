<script>
window.__notificationConfig = {
    ctx: '/TripTogether',
    locale: 'ko',
    labels: {
        typeCommunity: '[커뮤니티]',
        typeInquiry: '[문의]',
        typeReport: '[신고]',
        typeLevelup: '[레벨업]',
        typeGrade: '[등급]',
